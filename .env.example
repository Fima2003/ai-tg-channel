TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_BOT_TOKEN=123456789:bot_token_here
TELEGRAM_CHANNEL=@your_channel_username # For a private channel, use its numeric ID like -1001234567890 instead of @username
TIMEZONE=UTC
POST_TIME=09:00
MIN_IMAGES=1
MAX_IMAGES=4
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
STATE_FILE=.state/last_run.json
OUTPUT_DIR=.generated
MAX_RETRIES=3
DRY_RUN=false

CIVIT_API_KEY=api-key